}
.about-visual-panel {
  position: relative;
  background: var(--deep); border: 1px solid var(--border);
  min-height: 480px; overflow: hidden;
}
.heat-display {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 55% 65% at 42% 48%, rgba(212,98,42,.6) 0%, rgba(212,98,42,.25) 30%, rgba(10,20,50,.35) 58%, transparent 72%),
    radial-gradient(ellipse 28% 32% at 62% 32%, rgba(224,160,48,.38) 0%, transparent 50%),
    radial-gradient(ellipse 18% 22% at 28% 68%, rgba(212,98,42,.28) 0%, transparent 42%),
    linear-gradient(135deg, #040610 0%, #090c18 50%, #060608 100%);
  display: flex; align-items: center; justify-content: center;
}
.heat-crosshair {
  position: absolute; top: 48%; left: 43%; transform: translate(-50%,-50%);
  width: 56px; height: 56px;
}
.heat-crosshair::before, .heat-crosshair::after {
  content: ''; position: absolute; background: rgba(212,98,42,.5);
}
.heat-crosshair::before { top: 50%; left: 0; right: 0; height: 1px; }
.heat-crosshair::after { left: 50%; top: 0; bottom: 0; width: 1px; }
.heat-ring {
  position: absolute; inset: 6px; border: 1px solid rgba(212,98,42,.4);
  border-radius: 50%; animation: ringPulse 3s ease-in-out infinite;
}
.heat-ring2 {
  position: absolute; inset: -10px; border: 1px solid rgba(212,98,42,.15);
  border-radius: 50%; animation: ringPulse 3s ease-in-out infinite .5s;
}
@keyframes ringPulse { 0%,100%{opacity:.4;transform:scale(1)} 50%{opacity:1;transform:scale(1.05)} }
.heat-temp {
  position: absolute; top: 24px; right: 24px;
  font-family: var(--font-display); font-size: 2.8rem; font-weight: 300;
