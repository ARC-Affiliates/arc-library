<script>
(function() {

  /* ═══ CONTENT PROTECTION ═══ */
  // Disable right-click
  document.addEventListener('contextmenu', function(e) {
    e.preventDefault();
    return false;
  });

  // Disable drag on all images
  document.addEventListener('dragstart', function(e) {
    if (e.target.tagName === 'IMG') {
      e.preventDefault();
      return false;
    }
  });

  // Disable common keyboard shortcuts for saving/copying
  document.addEventListener('keydown', function(e) {
    // Block Ctrl+S, Ctrl+U, Ctrl+A, Ctrl+C, F12, Ctrl+Shift+I/J/C
    var blocked = (
      (e.ctrlKey && ['s','u','a','c','p'].includes(e.key.toLowerCase())) ||
      (e.ctrlKey && e.shiftKey && ['i','j','c'].includes(e.key.toLowerCase())) ||
      e.key === 'F12' ||
      e.key === 'PrintScreen'
    );
    if (blocked) {
      e.preventDefault();
      return false;
    }
  });

  // Disable text selection via mouse
  document.addEventListener('selectstart', function(e) {
    if (!['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName)) {
      e.preventDefault();
      return false;
    }
  });

  // Watermark console to deter dev tools users
  console.log('%c© 2026 Med-Hot Infrared Imaging, LLC. All rights reserved. Unauthorized use of images or content is prohibited.',
    'color: #d4622a; font-size: 14px; font-weight: bold; padding: 8px;');

  function showPage(id) {
    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });
    document.querySelectorAll('[data-nav-id]').forEach(function(b) { b.classList.remove('active'); });
    var page = document.getElementById('page-' + id);
    if (page) {
      page.classList.add('active');
      document.documentElement.scrollTop = 0;
      document.body.scrollTop = 0;
    }
    var navBtn = document.querySelector('[data-nav-id="' + id + '"]');
    if (navBtn) navBtn.classList.add('active');
    var mob = document.getElementById('mobileNav');
    var ham = document.getElementById('hamburger');
    if (mob) mob.classList.remove('open');
    if (ham) ham.classList.remove('open');
    document.body.style.overflow = '';
    if (id === 'home') initHeatCanvas();
    else initBgCanvas(id);
  }


  /* AMBIENT PAGE BACKGROUND */
  var bgCanvases = {};
  function initBgCanvas(id) {
    var canvas = document.getElementById('bg-canvas-' + id);
    if (!canvas || canvas._init) return;
    canvas._init = true;
    canvas.classList.add('visible');
    var ctx = canvas.getContext('2d');
    var W, H;
    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
    resize();
    window.addEventListener('resize', resize, { passive: true });
    var pts = [];
    for (var i = 0; i < 8; i++) {
      pts.push({
        x: Math.random(), y: Math.random(),
        vx: (Math.random()-.5)*.0002, vy: (Math.random()-.5)*.0002,
        r: 200 + Math.random()*350,
        t: Math.random(),
        life: Math.random()
      });
    }
    function draw() {
      ctx.clearRect(0,0,W,H);
      ctx.fillStyle = '#0d0e12';
      ctx.fillRect(0,0,W,H);
      pts.forEach(function(p) {
        p.x += p.vx; p.y += p.vy;
        if(p.x<-.2) p.x=1.2; if(p.x>1.2) p.x=-.2;
        if(p.y<-.2) p.y=1.2; if(p.y>1.2) p.y=-.2;
        var alpha = 0.06 + p.t * 0.08;
        var g = ctx.createRadialGradient(p.x*W, p.y*H, 0, p.x*W, p.y*H, p.r);
        g.addColorStop(0, 'rgba(212,98,42,' + alpha + ')');
        g.addColorStop(0.5, 'rgba(180,60,20,' + (alpha*0.4) + ')');
        g.addColorStop(1, 'transparent');
        ctx.fillStyle = g;
        ctx.fillRect(0,0,W,H);
      });
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  }

  document.addEventListener('click', function(e) {
    var t = e.target.closest('[data-page]');
    if (t) { e.preventDefault(); showPage(t.getAttribute('data-page')); return; }
    if (e.target.closest('.submit-btn-trigger')) {
      var s = document.getElementById('formSuccess');
      var f = document.querySelector('.form-footer');
      if (s) s.style.display = 'block';
      if (f) f.style.display = 'none';
    }
  });

  document.addEventListener('DOMContentLoaded', function() {
    var ham = document.getElementById('hamburger');
    var mob = document.getElementById('mobileNav');
    if (ham && mob) {
      ham.addEventListener('click', function() {
        var open = ham.classList.toggle('open');
        mob.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });
    }
    document.querySelectorAll('.why-item').forEach(function(item) {
      item.addEventListener('click', function() {
        document.querySelectorAll('.why-item').forEach(function(i) { i.classList.remove('active'); });
        item.classList.add('active');
      });
    });
    var email = 'info' + String.fromCharCode(64) + 'med-hot.com';
    document.querySelectorAll('.email-display').forEach(function(el) { el.textContent = email; });
    document.querySelectorAll('.mailto-link').forEach(function(el) { el.href = 'mailto:' + email; });
    initHeatCanvas();
    // init bg for any non-home active page on load
    var activePage = document.querySelector('.page.active');
    if (activePage && activePage.id !== 'page-home') {
      initBgCanvas(activePage.id.replace('page-',''));
    }
  });

  function initHeatCanvas() {
    var canvas = document.getElementById('heatCanvas');
    if (!canvas || canvas._init) return;
    canvas._init = true;
    var ctx = canvas.getContext('2d');
    var W, H, mx = .62, my = .42;
    function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
    resize();
    window.addEventListener('resize', resize, { passive: true });
    var hero = document.querySelector('.home-hero');
    if (hero) {
      hero.addEventListener('mousemove', function(e) {
        var r = hero.getBoundingClientRect();
        mx = (e.clientX-r.left)/r.width; my = (e.clientY-r.top)/r.height;
      }, { passive: true });
    }
    function HP() { this.reset(); }
    HP.prototype.reset = function() {
      this.x=Math.random(); this.y=Math.random();
      this.vx=(Math.random()-.5)*.00035; this.vy=(Math.random()-.5)*.00035;
      this.life=Math.random(); this.decay=.005+Math.random()*.006;
      this.r=130+Math.random()*240; this.t=Math.random();
    };
    HP.prototype.step = function() {
      this.x+=this.vx; this.y+=this.vy; this.life-=this.decay;
      if(this.life<=0||this.x<-.3||this.x>1.3||this.y<-.3||this.y>1.3) this.reset();
    };
    function tc(t,a) {
      var s=[[0,[10,10,80]],[.15,[15,80,160]],[.35,[15,150,90]],[.52,[170,170,15]],[.68,[210,90,15]],[.83,[235,40,15]],[1,[255,210,190]]];
      for(var i=0;i<s.length-1;i++){
        if(t>=s[i][0]&&t<=s[i+1][0]){
          var f=(t-s[i][0])/(s[i+1][0]-s[i][0]);
          var r=Math.round(s[i][1][0]+f*(s[i+1][1][0]-s[i][1][0]));
          var g=Math.round(s[i][1][1]+f*(s[i+1][1][1]-s[i][1][1]));
          var b=Math.round(s[i][1][2]+f*(s[i+1][1][2]-s[i][1][2]));
          return 'rgba('+r+','+g+','+b+','+a+')';
        }
      }
      return 'rgba(255,210,190,'+a+')';
    }
    var pts=[]; for(var i=0;i<22;i++) pts.push(new HP());
    var lt=0;
    function draw(ts) {
      if(ts-lt<16){requestAnimationFrame(draw);return;} lt=ts;
      ctx.clearRect(0,0,W,H); ctx.fillStyle='#0d0e12'; ctx.fillRect(0,0,W,H);
      var mg=ctx.createRadialGradient(mx*W,my*H,0,mx*W,my*H,W*.42);
      mg.addColorStop(0,'rgba(200,70,15,.32)');mg.addColorStop(.35,'rgba(140,40,8,.16)');mg.addColorStop(1,'transparent');
      ctx.fillStyle=mg; ctx.fillRect(0,0,W,H);
      pts.forEach(function(p){
        p.step();
        var px=p.x*W,py=p.y*H,dx=mx-p.x,dy=my-p.y,d=Math.sqrt(dx*dx+dy*dy);
        var temp=Math.min(1,p.t+Math.max(0,1-d/.42)*.5),alpha=Math.max(0,p.life)*.72;
        var g=ctx.createRadialGradient(px,py,0,px,py,p.r);
        g.addColorStop(0,tc(temp,alpha));g.addColorStop(.55,tc(temp*.5,alpha*.35));g.addColorStop(1,'transparent');
        ctx.fillStyle=g; ctx.fillRect(px-p.r,py-p.r,p.r*2,p.r*2);
      });
      var l=ctx.createLinearGradient(0,0,W*.5,0);
      l.addColorStop(0,'rgba(13,14,18,.7)');l.addColorStop(1,'transparent');
      ctx.fillStyle=l; ctx.fillRect(0,0,W,H);
      var bot=ctx.createLinearGradient(0,H*.5,0,H);
      bot.addColorStop(0,'transparent');bot.addColorStop(1,'rgba(13,14,18,.96)');
      ctx.fillStyle=bot; ctx.fillRect(0,0,W,H);
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  }
})();
</script>
