<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Med-Hot Infrared Imaging — Your Long-Term Solution</title>
<meta name="description" content="Med-Hot Infrared Imaging — Advanced medical thermography systems, clinical software, and practitioner training. FLIR Medical Partner since 2010. FDA 510k cleared.">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@200;300;400;500;600&family=Space+Mono&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   ROOT & RESET
═══════════════════════════════════════════ */
:root {
  --obsidian: #0d0e12;
  --deep: #13151c;
  --mid: #1a1d28;
  --surface: #222638;
  --copper: #d4622a;
  --copper-bright: #e8723a;
  --copper-pale: rgba(212,98,42,0.1);
  --amber: #e0a030;
  --cream: #f8f4ee;
  --white: #ffffff;
  --gray: #7a7e96;
  --gray-mid: #a8acbf;
  --gray-light: #d4d8ec;
  --text-primary: #f0f2ff;
  --text-secondary: #b8bcd4;
  --border: rgba(212,98,42,0.15);
  --border-mid: rgba(212,98,42,0.28);
  --border-bright: rgba(212,98,42,0.5);
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Outfit', system-ui, sans-serif;
  --font-mono: 'Space Mono', monospace;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-in-out: cubic-bezier(0.76, 0, 0.24, 1);
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { font-size: 16px; }
body {
  font-family: var(--font-body);
  background: var(--obsidian);
  color: var(--text-primary);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { text-decoration: none; color: inherit; }
button { border: none; background: none; cursor: pointer; font-family: inherit; }

/* ═══════════════════════════════════════════
   GRAIN
═══════════════════════════════════════════ */
.grain {
  position: fixed; inset: 0; z-index: 9000;
  pointer-events: none; opacity: 0.028;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 220px;
}

/* ═══════════════════════════════════════════
   NAV
═══════════════════════════════════════════ */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 500;
  padding: 0 40px;
  height: 72px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(13,14,18,0.96);
  backdrop-filter: blur(28px);
  border-bottom: 1px solid var(--border);
}

.nav-logo {
  display: flex; flex-direction: column; gap: 2px;
  cursor: pointer;
}
.nav-logo-word {
  font-family: var(--font-display);
  font-size: 1.4rem; font-weight: 600;
  letter-spacing: .08em; color: var(--white); line-height: 1;
  text-transform: lowercase; white-space: nowrap;
}
.nav-logo-tag {
  font-size: .48rem; font-weight: 300;
  letter-spacing: .22em; text-transform: uppercase;
  color: var(--amber); line-height: 1; white-space: nowrap;
}

.nav-links {
  display: flex; align-items: center; gap: 2px; list-style: none;
}

.nav-links button {
  font-family: var(--font-body);
  font-size: .62rem; font-weight: 300;
  letter-spacing: .12em; text-transform: uppercase;
  color: var(--gray-light);
  padding: 8px 10px;
  border-radius: 2px;
  transition: color .25s, background .25s;
  position: relative;
  background: none;
  border: none;
  cursor: pointer;
}
.nav-links button::after {
  content: ''; position: absolute; bottom: 4px; left: 16px; right: 16px;
  height: 1px; background: var(--amber);
  transform: scaleX(0); transform-origin: left;
  transition: transform .3s var(--ease-out);
}
.nav-links button:hover { color: var(--white); }
.nav-links button:hover::after { transform: scaleX(1); }
.nav-links button.active {
  color: var(--white);
}
.nav-links button.active::after { transform: scaleX(1); }

.nav-cta {
  font-family: var(--font-body) !important;
  font-size: .65rem !important; font-weight: 400 !important;
  letter-spacing: .18em !important; text-transform: uppercase !important;
  color: var(--amber) !important;
  border: 1px solid var(--border-mid) !important;
  padding: 10px 22px !important;
  margin-left: 8px;
  transition: background .3s, border-color .3s, color .3s !important;
}
.nav-cta::after { display: none !important; }
.nav-cta:hover {
  background: var(--copper) !important;
  border-color: var(--copper) !important;
  color: var(--white) !important;
}
.nav-cta.active {
  background: var(--copper) !important;
  border-color: var(--copper) !important;
  color: var(--white) !important;
}

/* hamburger */
.hamburger {
  display: none; flex-direction: column; gap: 5px;
  width: 32px; padding: 4px 0; cursor: pointer;
}
.hamburger span {
  display: block; height: 1px; background: var(--white);
  transition: transform .4s var(--ease-out), opacity .3s, width .3s;
  transform-origin: left;
}
.hamburger span:nth-child(2) { width: 70%; }
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(1px,-1px); }
.hamburger.open span:nth-child(2) { opacity: 0; width: 0; }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(1px,1px); }

/* mobile nav */
.mobile-nav {
  position: fixed; inset: 0; z-index: 490;
  background: var(--obsidian);
  display: flex; flex-direction: column;
  justify-content: center; align-items: center; gap: 4px;
  transform: translateX(100%);
  transition: transform .5s var(--ease-out);
  pointer-events: none;
}
.mobile-nav.open { transform: translateX(0); pointer-events: all; }
.mobile-nav button {
  font-family: var(--font-display);
  font-size: clamp(2rem,8vw,3.2rem);
  font-weight: 300; font-style: italic;
  color: var(--gray-mid); letter-spacing: .02em;
  transition: color .25s; background: none; border: none;
  cursor: pointer; padding: 8px 0; width: 100%; text-align: center;
}
.mobile-nav button:hover, .mobile-nav button.active { color: var(--white); }
.mobile-nav-divider { width: 40px; height: 1px; background: var(--border-mid); margin: 16px auto; }

@media (max-width: 900px) {
  nav { padding: 0 24px; }
  .nav-links { display: none; }
  .hamburger { display: flex; }
}

/* ═══════════════════════════════════════════
   PAGE SYSTEM
═══════════════════════════════════════════ */
.page {
  display: none !important;
  height: 0 !important;
  overflow: hidden !important;
  min-height: 0 !important;
  visibility: hidden !important;
  padding: 0 !important;
  margin: 0 !important;
}
.page.active {
  display: block !important;
  height: auto !important;
  overflow: visible !important;
  min-height: 100vh !important;
  visibility: visible !important;
  padding-top: 72px !important;
  margin: 0 !important;
  animation: pageIn .45s var(--ease-out) both;
}

/* AMBIENT CANVAS BACKGROUND */
.page-bg-canvas {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  pointer-events: none;
  opacity: 0;
  transition: opacity 1.2s ease;
}
.page-bg-canvas.visible { opacity: 1; }
.page > *:not(.page-bg-canvas) { position: relative; z-index: 1; }


@keyframes pageIn {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ═══════════════════════════════════════════
   SHARED TYPOGRAPHY & COMPONENTS
═══════════════════════════════════════════ */
.section-tag {
  display: inline-flex; align-items: center; gap: 14px;
  font-size: .58rem; font-weight: 300;
  letter-spacing: .38em; text-transform: uppercase; color: var(--amber);
  margin-bottom: 24px;
}
.section-tag::before { content: ''; width: 28px; height: 1px; background: var(--amber); flex-shrink: 0; }

.display-h1 {
  font-family: var(--font-display);
  font-size: clamp(3.5rem, 9vw, 9rem);
  font-weight: 300; line-height: .95; letter-spacing: -.02em;
}
.display-h1 em { font-style: italic; color: var(--copper-bright); }
.display-h1 strong { font-weight: 700; }

.display-h2 {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 5rem);
  font-weight: 300; line-height: 1.0; letter-spacing: -.01em;
}
.display-h2 em { font-style: italic; color: var(--copper-bright); }
.display-h2 strong { font-weight: 700; }

.display-h3 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.8rem);
  font-weight: 300; line-height: 1.15;
}
.display-h3 em { font-style: italic; color: var(--copper-bright); }

.body-p {
  font-size: clamp(.85rem,1.2vw,.95rem);
  font-weight: 300; line-height: 2.1; color: var(--text-secondary);
  letter-spacing: .02em;
}

.btn-outline {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: .68rem; font-weight: 400;
  letter-spacing: .22em; text-transform: uppercase;
  border: 1px solid var(--border-mid); color: var(--amber);
  padding: 15px 36px; cursor: pointer;
  transition: background .35s, border-color .35s, color .35s;
  position: relative; overflow: hidden; background: none;
  font-family: var(--font-body);
}
.btn-outline::before {
  content: ''; position: absolute; inset: 0;
  background: var(--copper); transform: translateX(-101%);
  transition: transform .4s var(--ease-out);
}
.btn-outline:hover::before { transform: translateX(0); }
.btn-outline:hover { color: var(--white); border-color: var(--copper); }
.btn-outline span { position: relative; z-index: 1; }
.btn-outline .arr { position: relative; z-index: 1; transition: transform .3s; }
.btn-outline:hover .arr { transform: translateX(4px); }

.btn-ghost {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: .68rem; font-weight: 300;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--gray-mid); transition: color .25s;
  background: none; border: none; cursor: pointer;
  font-family: var(--font-body);
}
.btn-ghost:hover { color: var(--white); }

/* reveal - disabled, content always visible */
[data-reveal] { opacity: 1; transform: none; }
[data-reveal].revealed { opacity: 1; transform: none; }
[data-delay="1"], [data-delay="2"], [data-delay="3"],
[data-delay="4"], [data-delay="5"], [data-delay="6"] { transition-delay: 0s; }

/* page hero banner */
.page-hero {
  padding: clamp(48px,6vw,80px) clamp(24px,6vw,80px) clamp(32px,4vw,48px);
  border-bottom: 1px solid var(--border);
  position: relative; overflow: hidden;
}
.page-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(212,98,42,.07) 0%, transparent 65%);
  pointer-events: none;
}

/* divider */
.hr { width: 100%; height: 1px; background: var(--border); }

/* pull quote */
.pullquote-block {
  padding: clamp(48px,6vw,80px) clamp(24px,6vw,80px);
  background: var(--deep);
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  display: grid; grid-template-columns: auto 1fr; gap: clamp(28px,4vw,56px);
  align-items: start; position: relative; overflow: hidden;
}
.pullquote-block::before {
  content: '\201C';
  position: absolute; top: 0; left: clamp(20px,4vw,60px);
  font-family: var(--font-display); font-size: clamp(6rem,15vw,14rem);
  font-weight: 700; color: rgba(212,98,42,.06);
  line-height: 1; pointer-events: none;
}
.q-rule { width: 1px; min-height: 100px; background: linear-gradient(to bottom, var(--amber), transparent); flex-shrink: 0; }
.pullquote-block blockquote {
  font-family: var(--font-display);
  font-size: clamp(1.3rem,2.8vw,2.5rem);
  font-weight: 300; font-style: italic; line-height: 1.5;
  color: var(--text-primary); margin-bottom: 20px;
  position: relative; z-index: 1;
}
.pullquote-block cite {
  display: block; font-style: normal; font-family: var(--font-body);
  font-size: .6rem; font-weight: 300;
  letter-spacing: .28em; text-transform: uppercase; color: var(--amber);
  position: relative; z-index: 1;
}

/* ═══════════════════════════════════════════
   PAGE: HOME
═══════════════════════════════════════════ */
#page-home {
  display: block;
}

.home-hero {
  position: relative; min-height: calc(100vh - 72px);
  display: flex; flex-direction: column; justify-content: flex-end;
  overflow: hidden;
}
#heatCanvas {
  position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0;
}
.home-hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background:
    linear-gradient(to right, rgba(13,14,18,.92) 20%, rgba(13,14,18,.55) 55%, rgba(13,14,18,.1) 100%),
    linear-gradient(to top, rgba(13,14,18,.97) 12%, rgba(13,14,18,.3) 45%, transparent 75%);
}
.home-hero-content {
  position: relative; z-index: 2;
  padding: 0 clamp(24px,6vw,80px) clamp(80px,10vw,120px);
  max-width: 820px;
}
.hero-eyebrow {
  display: flex; align-items: center; gap: 16px; margin-bottom: 36px; margin-top: 48px;
  animation: fadeUp .9s var(--ease-out) .3s both;
}
.hero-eyebrow-line { width: 40px; height: 1px; background: var(--amber); }
.hero-eyebrow-text {
  font-size: .6rem; font-weight: 300;
  letter-spacing: .32em; text-transform: uppercase; color: var(--amber);
}
.home-h1 {
  font-family: var(--font-display);
  font-size: clamp(3.8rem,10vw,10rem);
  font-weight: 300; line-height: .92; letter-spacing: -.02em;
  margin-bottom: 40px;
  animation: fadeUp .9s var(--ease-out) .5s both;
}
.home-h1 em { font-style: italic; color: var(--copper-bright); }
.home-h1 strong { font-weight: 700; display: block; }
.home-rule {
  width: 64px; height: 1px;
  background: linear-gradient(90deg, var(--amber), transparent);
  margin-bottom: 24px;
  animation: fadeIn .9s var(--ease-out) .9s both;
}
.home-desc {
  font-size: clamp(.9rem,1.5vw,1.05rem); font-weight: 300; line-height: 2;
  color: var(--text-secondary); max-width: 500px; margin-bottom: 48px;
  animation: fadeUp .9s var(--ease-out) 1s both;
}
.home-actions {
  display: flex; gap: 20px; align-items: center; flex-wrap: wrap;
  animation: fadeUp .9s var(--ease-out) 1.15s both;
}
.home-scroll {
  position: absolute; right: clamp(24px,4vw,60px); bottom: 48px; z-index: 2;
  display: flex; flex-direction: column; align-items: center; gap: 10px;
}
.home-scroll-line {
  width: 1px; height: 60px;
  background: linear-gradient(to bottom, var(--amber), transparent);
  animation: scrollPulse 2.5s ease-in-out infinite;
}
.home-scroll-lbl {
  font-size: .5rem; letter-spacing: .3em; text-transform: uppercase;
  color: var(--gray); writing-mode: vertical-lr;
}
@keyframes scrollPulse { 0%,100%{opacity:.3} 50%{opacity:1} }

/* marquee */
.marquee {
  background: var(--deep); overflow: hidden;
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  padding: 14px 0; white-space: nowrap;
}
.marquee-track { display: inline-flex; animation: marqueeAnim 36s linear infinite; }
.marquee:hover .marquee-track { animation-play-state: paused; }
.m-item {
  display: inline-flex; align-items: center; gap: 20px; padding: 0 36px;
  font-size: .6rem; font-weight: 300;
  letter-spacing: .3em; text-transform: uppercase; color: var(--gray);
}
.m-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--copper); flex-shrink: 0; }
@keyframes marqueeAnim { from{transform:translateX(0)} to{transform:translateX(-50%)} }

/* home mission block */
.home-mission {
  padding: clamp(80px,10vw,140px) clamp(24px,6vw,80px);
  display: grid; grid-template-columns: auto 1fr; gap: clamp(40px,8vw,120px);
  align-items: center; border-bottom: 1px solid var(--border);
}
.home-mission-num {
  font-family: var(--font-display);
  font-size: clamp(5rem,12vw,12rem); font-weight: 700; line-height: 1;
  color: rgba(212,98,42,.07); letter-spacing: -.04em; user-select: none;
}
.home-mission-text {
  font-family: var(--font-display);
  font-size: clamp(1.6rem,3.2vw,3rem);
  font-weight: 300; line-height: 1.5; color: var(--text-primary);
  letter-spacing: .01em; margin-bottom: 28px;
}
.home-mission-text em { font-style: italic; color: var(--copper-bright); }

/* home 4-pillar grid */
.home-pillars {
  display: grid; grid-template-columns: repeat(2,1fr);
  border-top: 1px solid var(--border); border-left: 1px solid var(--border);
}
.home-pillar {
  border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);
  padding: clamp(36px,4vw,56px) clamp(24px,3.5vw,48px);
  transition: background .3s; cursor: default; position: relative; overflow: hidden;
}
.home-pillar::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, var(--copper), var(--amber), transparent);
  transform: scaleX(0); transform-origin: left;
  transition: transform .5s var(--ease-out);
}
.home-pillar:hover { background: rgba(212,98,42,.03); }
.home-pillar:hover::before { transform: scaleX(1); }
.pillar-num {
  font-family: var(--font-display); font-size: .78rem;
  color: var(--copper); letter-spacing: .15em; margin-bottom: 32px; display: block;
}
.pillar-title {
  font-family: var(--font-display); font-size: clamp(1.3rem,2vw,1.8rem);
  font-weight: 400; line-height: 1.2; margin-bottom: 16px; color: var(--white);
}
.pillar-desc {
  font-size: clamp(.78rem,1vw,.875rem); font-weight: 300;
  line-height: 1.95; color: var(--text-secondary);
}
.pillar-btn {
  margin-top: 28px;
  font-size: .62rem; font-weight: 300; letter-spacing: .18em;
  text-transform: uppercase; color: var(--copper);
  display: inline-flex; align-items: center; gap: 6px;
  transition: gap .3s; background: none; border: none; cursor: pointer;
  font-family: var(--font-body);
}
.pillar-btn:hover { gap: 10px; }

/* home stats row */
.home-stats {
  display: grid; grid-template-columns: repeat(4,1fr);
  background: var(--deep);
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  padding: clamp(48px,6vw,80px) clamp(24px,6vw,80px);
}
.h-stat { padding: 0 clamp(16px,3vw,40px); border-right: 1px solid var(--border); }
.h-stat:first-child { padding-left: 0; }
.h-stat:last-child { border-right: none; }
.h-stat-fig {
  font-family: var(--font-display);
  font-size: clamp(2.5rem,4.5vw,4.5rem);
  font-weight: 300; line-height: 1; color: var(--white); letter-spacing: -.03em;
}
.h-stat-fig em { font-style: italic; color: var(--copper-bright); }
.h-stat-lbl {
  font-size: .58rem; font-weight: 300; letter-spacing: .25em;
  text-transform: uppercase; color: var(--gray); margin-top: 10px;
}
.h-stat-sub { font-size: .73rem; color: var(--text-secondary); margin-top: 6px; font-weight: 300; line-height: 1.6; }

/* home CTA strip */
.home-cta-strip {
  padding: clamp(80px,10vw,120px) clamp(24px,6vw,80px);
  display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center;
}
.home-cta-strip h2 { font-family: var(--font-display); font-size: clamp(2rem,4vw,4rem); font-weight: 300; line-height: 1.1; }
.home-cta-strip h2 em { font-style: italic; color: var(--copper-bright); }
.home-cta-actions { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; flex-shrink: 0; }

@media (max-width: 900px) {
  .home-mission { grid-template-columns: 1fr; gap: 0; }
  .home-mission-num { font-size: 5rem; margin-bottom: -24px; }
  .home-pillars { grid-template-columns: 1fr; }
  .home-stats { grid-template-columns: 1fr 1fr; gap: 40px; }
  .h-stat { border-right: none; padding: 0; }
  .home-cta-strip { grid-template-columns: 1fr; }
}

/* ═══════════════════════════════════════════
   PAGE: WHY THERMOGRAPHY
═══════════════════════════════════════════ */
.why-body {
  padding: clamp(60px,8vw,100px) clamp(24px,6vw,80px);
  display: grid; grid-template-columns: 1fr 1.2fr; gap: clamp(48px,8vw,120px); align-items: start;
}
.why-sticky { position: sticky; top: 96px; }
.why-list { display: flex; flex-direction: column; }
.why-item {
  display: grid; grid-template-columns: 36px 1fr; gap: 20px;
  padding: clamp(20px,2.5vw,32px) 0;
  border-bottom: 1px solid var(--border);
  cursor: pointer; transition: background .2s;
}
.why-item:first-child { border-top: 1px solid var(--border); }
.why-num { font-family: var(--font-display); font-size: .9rem; color: var(--copper); margin-top: 2px; }
.why-title {
  font-size: clamp(.85rem,1.1vw,.95rem); font-weight: 500;
  letter-spacing: .04em; color: var(--text-primary); margin-bottom: 8px; transition: color .25s;
}
.why-desc {
  font-size: clamp(.78rem,.95vw,.85rem); font-weight: 300;
